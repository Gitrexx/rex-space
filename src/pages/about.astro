---
import '../styles/pages/about.css';
import config from '../../astro-theme-config';
import BaseLayout from '../layouts/BaseLayout.astro';

const { about, social, site } = config;

const profileImageUrl = about.profileImage.trim();
const hasProfileImage = profileImageUrl.length > 0;
const profileName = about.name || site.author;
const [headlineFirst, headlineSecond] = about.headline;

const profileLinks = [
  { label: 'GitHub', href: social.github },
  { label: 'LinkedIn', href: social.linkedin },
  { label: 'Website', href: social.website },
  { label: 'Email', href: social.email ? `mailto:${social.email}` : '' },
].filter((link) => link.href);
---

<BaseLayout title="About" description={`${about.role} · ${about.focus}`}>
  <main id="main-content" class="about-main">
    <section class="about-hero" aria-labelledby="about-title">
      <div class="about-intro">
        <h1 id="about-title" class="about-title">
          {headlineFirst}<br />
          {headlineSecond}
        </h1>
        <ul class="about-tags" aria-label="Focus areas and expertise">
          {about.tags.map((tag) => <li>{tag}</li>)}
        </ul>
      </div>

      <aside
        class:list={['profile-panel', !hasProfileImage && 'profile-panel--text']}
        aria-label="Profile preview"
      >
        {
          hasProfileImage && (
            <figure class="profile-media">
              <img
                src={profileImageUrl}
                width="720"
                height="720"
                alt={`${profileName} profile portrait`}
                loading="eager"
                referrerpolicy="no-referrer"
              />
            </figure>
          )
        }
        <div class="profile-summary">
          <p class="profile-name">{profileName}</p>
          <p class="profile-role">{about.role}</p>
        </div>
        <dl class="profile-meta">
          <div>
            <dt>Location</dt>
            <dd>{about.location}</dd>
          </div>
          <div>
            <dt>Focus</dt>
            <dd>{about.focus}</dd>
          </div>
          {
            profileLinks.length > 0 && (
              <div>
                <dt>Links</dt>
                <dd class="profile-links">
                  {profileLinks.map((link) => (
                    <a
                      href={link.href}
                      target={link.href.startsWith('mailto:') ? undefined : '_blank'}
                      rel={link.href.startsWith('mailto:') ? undefined : 'noopener'}
                    >
                      {link.label}
                    </a>
                  ))}
                </dd>
              </div>
            )
          }
        </dl>
      </aside>
    </section>

    <section class="about-section about-statement" aria-labelledby="about-statement">
      <p class="section-label">{about.statementLabel}</p>
      <div>
        <h2 id="about-statement" class="section-heading">
          {about.statementTitle}
        </h2>
        <p>{about.statement}</p>
      </div>
    </section>

    <section class="about-section" aria-label={about.experienceLabel}>
      <p class="section-label">{about.experienceLabel}</p>
      <div class="career-list">
        {
          about.experience.map((item) => (
            <article class="career-item">
              <time>{item.period}</time>
              <div>
                <h3>{item.title}</h3>
                <p class="career-company">{item.company}</p>
                <ul class="career-highlights">
                  {item.highlights.map((highlight) => (
                    <li>{highlight}</li>
                  ))}
                </ul>
              </div>
            </article>
          ))
        }
      </div>
    </section>

    <section class="about-section" aria-label={about.educationLabel}>
      <p class="section-label">{about.educationLabel}</p>
      <div class="career-list">
        {
          about.education.map((item) => (
            <article class="career-item">
              <time>{item.period}</time>
              <div>
                <h3>{item.title}</h3>
                <p class="career-company">{item.school}</p>
                {item.note && <p>{item.note}</p>}
              </div>
            </article>
          ))
        }
      </div>
    </section>

    <section class="about-section" aria-labelledby="about-skills">
      <p class="section-label">{about.skillsLabel}</p>
      <div>
        <h2 id="about-skills" class="section-heading">{about.skillsHeading}</h2>
        <dl class="skills-list">
          {
            about.skills.map((skill) => (
              <div>
                <dt>{skill.group}</dt>
                <dd>{skill.items}</dd>
              </div>
            ))
          }
        </dl>
      </div>
    </section>

    <section class="about-section" aria-labelledby="about-awards">
      <p class="section-label">{about.awardsLabel}</p>
      <div>
        <h2 id="about-awards" class="section-heading">{about.awardsHeading}</h2>
        <ul class="focus-list">
          {about.awards.map((award) => <li>{award}</li>)}
        </ul>
      </div>
    </section>

    <section class="about-section" aria-label={about.languagesLabel}>
      <p class="section-label">{about.languagesLabel}</p>
      <div class="about-languages">
        <p>{about.languages}</p>
      </div>
    </section>
  </main>
</BaseLayout>
