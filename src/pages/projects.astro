---
import '../styles/pages/projects.css';
import config from '../../astro-theme-config';
import BaseLayout from '../layouts/BaseLayout.astro';
import { withBase } from '../utils/paths';

const { projects } = config;
const items = projects.items ?? [];
const hasItems = items.length > 0;

// One flat list, sorted alphabetically by title — no tag sections.
const sortedItems = [...items].sort((a, b) => a.title.localeCompare(b.title));

// Distinct tags across all items, alphabetical — drives the filter chip row.
const allTags = Array.from(
  new Set(
    items
      .flatMap((item) => item.tags ?? [])
      .map((tag) => tag.trim())
      .filter(Boolean),
  ),
).sort((a, b) => a.localeCompare(b));

// Delimited, lowercased tag string per card so the filter can match a whole
// tag (`|react|`) without partial collisions (e.g. 'react' vs 'react native').
const tagKey = (tags?: string[]) =>
  tags && tags.length ? `|${tags.map((t) => t.trim().toLowerCase()).join('|')}|` : '';
---

<BaseLayout title={projects.title} description={projects.intro}>
  <main id="main-content" class="projects-main" data-projects>
    <header class="projects-hero">
      <p class="projects-eyebrow eyebrow-accent">{projects.eyebrow}</p>
      <h1 class="projects-title">{projects.title}</h1>
      <p class="projects-intro">{projects.intro}</p>
    </header>

    {
      hasItems ? (
        <>
          <div class="projects-controls">
            <div class="projects-search">
              <label class="projects-search-field">
                <span class="sr-only">Search projects</span>
                <span class="projects-search-icon" aria-hidden="true">
                  <svg
                    width="18"
                    height="18"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    focusable="false"
                  >
                    <circle cx="11" cy="11" r="7" />
                    <path d="m16 16 4 4" />
                  </svg>
                </span>
                <input
                  type="search"
                  class="projects-search-input"
                  data-projects-search
                  placeholder="Search projects…"
                  autocomplete="off"
                  spellcheck="false"
                  aria-controls="projects-grid"
                />
              </label>
              <p class="projects-search-status" data-projects-status role="status" aria-live="polite" />
            </div>

            {allTags.length > 0 && (
              <div class="projects-filters" role="group" aria-label="Filter by tag" data-projects-filters>
                {allTags.map((tag) => (
                  <button
                    type="button"
                    class="projects-filter"
                    data-tag={tag.toLowerCase()}
                    aria-pressed="false"
                  >
                    {tag}
                  </button>
                ))}
              </div>
            )}
          </div>

          <ul class="projects-grid" id="projects-grid" data-projects-grid>
            {sortedItems.map((item) => (
              <li
                class="project-card-item"
                data-card
                data-search={`${item.title} ${item.description} ${(item.tags ?? []).join(' ')}`.toLowerCase()}
                data-tags={tagKey(item.tags)}
              >
                <a class="project-card" href={withBase(`/projects/${item.slug}/`)}>
                  <span class="project-card-title">{item.title}</span>
                  {item.tags && item.tags.length > 0 && (
                    <span class="project-card-tags">
                      {item.tags.map((tag) => (
                        <span class="project-card-tag">{tag}</span>
                      ))}
                    </span>
                  )}
                  <span class="project-card-desc">{item.description}</span>
                  <span class="project-card-cta">
                    <span>View</span>
                    <span class="project-card-arrow" aria-hidden="true">
                      →
                    </span>
                  </span>
                </a>
              </li>
            ))}
          </ul>
          <p class="projects-empty" data-projects-empty hidden>
            No projects match your filters.
          </p>
        </>
      ) : (
        <p class="projects-empty-static">No projects yet — check back soon.</p>
      )
    }
  </main>
</BaseLayout>

<script>
  function mountProjectsSearch() {
    const root = document.querySelector<HTMLElement>('[data-projects]');
    if (!root) return;

    const input = root.querySelector<HTMLInputElement>('[data-projects-search]');
    const cards = Array.from(root.querySelectorAll<HTMLElement>('[data-card]'));
    const filters = Array.from(root.querySelectorAll<HTMLButtonElement>('[data-projects-filters] button'));
    const status = root.querySelector<HTMLElement>('[data-projects-status]');
    const empty = root.querySelector<HTMLElement>('[data-projects-empty]');

    const activeTags = new Set<string>();

    function apply() {
      const query = (input?.value ?? '').trim().toLowerCase();
      let visible = 0;

      for (const card of cards) {
        const textMatch = query === '' || (card.dataset.search ?? '').includes(query);
        const cardTags = card.dataset.tags ?? '';
        const tagMatch =
          activeTags.size === 0 || Array.from(activeTags).some((tag) => cardTags.includes(`|${tag}|`));
        const match = textMatch && tagMatch;
        card.hidden = !match;
        if (match) visible += 1;
      }

      if (empty) empty.hidden = visible !== 0;
      if (status) {
        const filtered = query !== '' || activeTags.size > 0;
        status.textContent = filtered ? `${visible} ${visible === 1 ? 'project' : 'projects'}` : '';
      }
    }

    if (input) {
      input.addEventListener('input', apply);
      input.addEventListener('keydown', (event) => {
        if (event.key === 'Escape') {
          input.value = '';
          apply();
        }
      });
    }

    for (const button of filters) {
      button.addEventListener('click', () => {
        const tag = button.dataset.tag ?? '';
        const next = button.getAttribute('aria-pressed') !== 'true';
        button.setAttribute('aria-pressed', String(next));
        if (next) activeTags.add(tag);
        else activeTags.delete(tag);
        apply();
      });
    }

    apply();
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', mountProjectsSearch, { once: true });
  } else {
    mountProjectsSearch();
  }
</script>
